{
  "name": "tolli",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "firebase": "12.13.0",
      "react": "19.1.0",
      "react-dom": "19.1.0"
    }
  },
  "scripts": {
    "web": "pnpm --filter web dev",
    "web:prod": "pnpm --filter web build && pnpm --filter web start",
    "native": "pnpm --filter native start",
    "ios": "pnpm --filter native ios",
    "android": "pnpm --filter native android",
    "ios:device": "pnpm --filter native ios:device",
    "android:device": "pnpm --filter native android:device"
  }
}
